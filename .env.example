# Backend (apps/backend) — copy to apps/backend/.env or set in docker-compose / Fly
DATABASE_URL=postgresql+psycopg2://arewapay:arewapay@localhost:5432/arewapay
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-long-random-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# Email (Resend) — required for signup OTP and lifecycle mail in production.
# Never commit a real API key. Use Fly secrets / host env in deployment.
RESEND_API_KEY=
# Routable address must be on a domain verified in Resend.
# Optional “mask”: show branded address as display name, send from verified domain, e.g.:
#   EMAIL_FROM="noreply@arewapay.africa <noreply@yourverified.com>"
# Or use a verified ArewaPay domain directly: ArewaPay <noreply@arewapay.africa>
EMAIL_FROM=ArewaPay <noreply@example.com>

# Docker Compose
JWT_SECRET=change-me-use-long-random-string-in-production
# Host port for nginx frontend (http://localhost:<port>). If 8080 is busy (e.g. another dev server), set 8081.
FRONTEND_PORT=8080

# RevenueCat (optional backend webhook — tier mapping if you use RC server events)
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_PREMIUM_PRODUCT_IDS=premium_monthly,premium_yearly
REVENUECAT_UNLIMITED_PRODUCT_IDS=lifetime

# Frontend — Vite loads env from the monorepo root (see apps/frontend/vite.config.ts envDir).
