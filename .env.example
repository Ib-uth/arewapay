# Backend (apps/backend) — copy to apps/backend/.env or set in docker-compose / Railway
DATABASE_URL=postgresql+psycopg2://arewapay:arewapay@localhost:5432/arewapay
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-long-random-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# Email (Resend) — optional; verification emails skipped if unset
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Docker Compose
JWT_SECRET=change-me-use-long-random-string-in-production

# RevenueCat (backend webhook — map products to tiers in RevenueCat dashboard)
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_PREMIUM_PRODUCT_IDS=premium_monthly,premium_yearly
REVENUECAT_UNLIMITED_PRODUCT_IDS=lifetime

# Frontend — Vite loads env from the monorepo root (see apps/frontend/vite.config.ts envDir).
# Put VITE_REVENUECAT_API_KEY in `.env.local` here for local dev, or in `.env` for Docker Compose
# (Compose reads `.env` next to docker-compose.yml for ${VITE_REVENUECAT_API_KEY}; `.env.local` is not loaded by Compose by default).
# VITE_REVENUECAT_API_KEY=
